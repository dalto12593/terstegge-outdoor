---
// src/components/home/ServiceArea.astro
// Simple service area callout — Quincy and surrounding area.

import { MapPin } from '@lucide/astro';
---

<section id="service-area" class="bg-forest-dark py-16 px-4 scroll-mt-16">
  <div class="max-w-5xl mx-auto text-center">

    <MapPin size={28} class="text-gold mx-auto mb-4" />

    <h2 class="text-3xl font-serif text-white">Serving the Quincy, IL Area</h2>
    <div class="w-12 h-0.5 bg-gold mx-auto mt-3" aria-hidden="true"></div>

    <p class="text-white/70 text-base max-w-lg mx-auto mt-6 leading-relaxed">
      Proudly serving residential and commercial properties in Quincy and the surrounding area. Contact us to see if we cover your location.
    </p>

  </div>
</section>
