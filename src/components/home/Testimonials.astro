    <div class="text-6xl font-serif text-gold leading-none" aria-hidden="true">&ldquo;</div>

    <!-- Quote text -->
    <p class="text-lg md:text-xl text-gray-700 italic leading-relaxed">
      They did an excellent job with our yard. Professional, on time, and the lawn looks better than ever. Highly recommend Terstegge Outdoor Services!
    </p>

    <!-- Attribution -->
    <p class="mt-4 text-sm text-gray-500 font-medium">— Satisfied Customer, Quincy IL</p>

  </div>
</section>
