---
// src/components/home/Hero.astro
// Hero section: tree/lawn image at natural aspect ratio, text overlaid on top.
// The image drives the height — no cropping, full tree always visible.
// Desktop (md+): left-aligned text. Mobile (<md): centered, pushed lower.
---

<section class="relative bg-forest-dark">
  <!-- Image at natural size — drives the section height -->
  <img
    src="/hero-bg.jpg"
    alt="Terstegge Outdoor Services — tree with roots in a freshly mowed lawn"
    class="w-full h-auto block"
    width="1600"
    height="631"
    loading="eager"
  />

  <!-- Text overlaid on the dark green sky area of the image -->
  <div class="hero-content absolute inset-0 px-5 sm:px-8 md:px-12 lg:px-16">
    <h1 class="font-sans font-bold tracking-tight leading-none
               text-3xl sm:text-4xl md:text-5xl">
      <span class="text-gold block">Terstegge</span>
      <span class="text-white block mt-0.5 md:mt-1">Outdoor Services</span>
    </h1>

    <p class="text-white/70 max-w-sm leading-relaxed
              text-sm md:text-base
              mt-3 md:mt-4
              mx-auto md:mx-0">
      Professional mowing, landscaping, shrub trimming &amp; snow removal —
      serving the Quincy, IL area.
    </p>

    <a
      href="#contact"
      class="inline-block bg-gold hover:bg-gold-dark text-forest-dark font-semibold rounded transition
             text-sm md:text-base
             px-6 md:px-8 py-2.5 md:py-3
             mt-4 md:mt-5"
    >
      Get a Free Quote
    </a>
  </div>
</section>

<style>
  /* Mobile: centered, text in upper portion */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: flex-start;
    padding-top: 24px;
  }

  /* Desktop: left-aligned, vertically centered */
  @media (min-width: 768px) {
    .hero-content {
      align-items: flex-start;
      text-align: left;
      justify-content: center;
      padding-top: 0;
    }
  }
</style>
