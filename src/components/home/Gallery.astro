---
// src/components/home/Gallery.astro
// "Our Work" photo gallery showcasing completed mowing and landscaping jobs.

const photos = [
  { src: '/gallery/work-1.jpg', alt: 'Freshly mowed backyard with clean stripe pattern' },
  { src: '/gallery/work-2.jpg', alt: 'Toro commercial mower on a diamond-striped lawn' },
  { src: '/gallery/work-3.jpg', alt: 'Commercial church property with professional mowing' },
  { src: '/gallery/work-4.jpg', alt: 'Lawn care service with American flag display' },
  { src: '/gallery/work-5.jpg', alt: 'Large commercial property with crosshatch mowing pattern' },
  { src: '/gallery/work-6.jpg', alt: 'Multiple residential and commercial mowing projects' },
];
---

<section id="gallery" class="bg-forest-dark py-16 px-4 scroll-mt-16">
  <div class="max-w-5xl mx-auto">

    <!-- Section heading + gold rule -->
    <h2 class="text-3xl font-serif text-white text-center">Our Work</h2>
    <div class="w-12 h-0.5 bg-gold mx-auto mt-3 mb-12" aria-hidden="true"></div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      {photos.map(({ src, alt }) => (
        <div class="rounded-lg overflow-hidden border border-gold/35 hover:border-gold/70 transition-all duration-200">
          <img
            src={src}
            alt={alt}
            class="w-full h-full object-cover aspect-square"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
