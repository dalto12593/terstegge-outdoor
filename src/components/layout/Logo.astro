---
// src/components/layout/Logo.astro
// Renders the business logo at the specified size.
// The logo is a transparent PNG shown in its natural colors on any background.

interface Props {
  size?: number;
  class?: string;
}

const { size = 36, class: className = '' } = Astro.props;
---

<img
  src="/logo.png"
  height={size}
  alt="Terstegge Outdoor Services logo"
  class={`inline-block ${className}`}
  style={`height: ${size}px; width: auto;`}
/>
